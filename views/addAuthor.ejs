<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Author</title>
</head>

<body>

    <form action="/" method="GET">
        <button>Home</button>
    </form>

    <h1>Adding a New Author</h1>

    <form action="/addAuthor" method="POST">
        First Name:
        <input type="text" name="firstName"> <br>

        Last Name:
        <input type="text" name="lastName"> <br>

        Date of Birth:
        <input type="date" name="dob"> <br>

        Date of Death:
        <input type="date" name="dod"> <br>

        Sex:
        <label><input type="radio" value="F" name="sex"> F </label>
        <label><input type="radio" value="M" name="sex"> M </label> <br>

        Biography:
        <textarea name="bio"></textarea> <br>

        Profession:
        <input type="text" name="profession"> <br>

        Country:
        <input type="text" name="country"> <br>

        Portrait URL:
        <input type="text" name="portrait"> <br>

        <button>Add Author!</button>
    </form>

</body>

</html>